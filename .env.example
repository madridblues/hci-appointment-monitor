# Appointment monitoring configuration
# ======================================

# Target URL parameters
APPOINTMENT_URL=https://appointment.hcilondon.gov.in/appointment.php
MONTH=04
YEAR=2026
APT_TYPE=Submission
LOCATION_ID=8
SERVICE_ID=29

# Monitoring settings
CHECK_INTERVAL_SECONDS=300
# Comma-separated list of months to monitor (e.g., 04,05,06). Leave empty to use MONTH above.
MONITOR_MONTHS=

# Email notification settings (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com

# Webhook notification settings
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-url.example.com
# Optional: additional headers as JSON (e.g., {"Authorization": "Bearer token"})
WEBHOOK_HEADERS=

# Proxy settings (optional)
# Supports HTTP, HTTPS, and SOCKS5 proxies
# Examples:
#   PROXY_URL=http://proxy-host:8080
#   PROXY_URL=http://user:password@proxy-host:8080
#   PROXY_URL=socks5://proxy-host:1080
PROXY_URL=

# Dashboard settings
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
