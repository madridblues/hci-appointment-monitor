# Appointment monitoring configuration
# ======================================

# Target URL parameters
APPOINTMENT_URL=https://appointment.hcilondon.gov.in/appointment.php
APT_TYPE=Submission
SERVICE_ID=29
YEAR=2026

# Locations to monitor (comma-separated IDs)
# 3=London Goswell, 4=London Hounslow, 8=Leicester, 9=Bradford,
# 10=Manchester, 14=Birmingham, 22=Belfast, 23=Cardiff
LOCATION_IDS=3,4,8,9,10,14,22,23

# Months to monitor (comma-separated, 01-12)
MONITOR_MONTHS=03,04

# Monitoring settings
CHECK_INTERVAL_SECONDS=300

# Email notification settings (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com

# Webhook notification settings
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-url.example.com
# Optional: additional headers as JSON (e.g., {"Authorization": "Bearer token"})
WEBHOOK_HEADERS=

# Proxy settings (optional)
PROXY_URL=

# Dashboard settings
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
